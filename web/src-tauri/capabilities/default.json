{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for kvelmo desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/kvelmo", "sidecar": true, "args": true },
        { "cmd": "wsl", "args": true }
      ]
    },
    "shell:allow-kill",
    "shell:allow-open",
    "dialog:default",
    "process:default",
    "notification:default",
    "updater:default",
    "global-shortcut:allow-register",
    "deep-link:default"
  ]
}
